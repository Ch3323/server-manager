generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  MOD
  ADMIN
}

enum AuthTokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

enum WorkspaceAccess {
  VIEW
  EDIT
}

model User {
  id              String          @id @default(uuid())
  email           String          @unique
  password        String
  role            Role            @default(USER)
  workspacePath   String          @default("")
  workspaceAccess WorkspaceAccess @default(VIEW)
  emailVerifiedAt DateTime?
  createdAt       DateTime        @default(now())
}

model AuthToken {
  id        String        @id @default(uuid())
  email     String
  tokenHash String        @unique
  type      AuthTokenType
  expiresAt DateTime
  createdAt DateTime      @default(now())

  @@index([email, type])
  @@index([expiresAt])
}

model ActivityLog {
  id            String   @id @default(uuid())
  actorEmail    String
  actorRole     Role
  action        String
  containerName String?
  createdAt     DateTime @default(now())
}
