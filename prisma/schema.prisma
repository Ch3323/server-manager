generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  MOD
  ADMIN
}

model User {
  id       String @id @default(uuid())
  email    String @unique
  password String
  role     Role     @default(USER)
  createdAt DateTime @default(now())
}

model ActivityLog {
  id            String   @id @default(uuid())
  actorEmail    String
  actorRole     Role
  action        String
  containerName String?
  createdAt     DateTime @default(now())
}
